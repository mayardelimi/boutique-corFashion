{% extends 'base.html.twig' %}

{% block title %}Hello LoginController!{% endblock %}

{% block body %}
<div class = 'container my-5'>
    <h1>Connexion</h1>
    {% if error %}
        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form action="{{ path('app_login') }}" method="post">
        <label for="username">votre email:</label>
        <input class="form-control mb-3" type="text" id="username" name="_username" value="{{ last_username }}" required>

        <label for="password">votre mot de passe :</label>
        <input class="form-control " type="password" id="password" name="_password" required>

        <input type="hidden" name="_target_path" value={{ path("app_account") }}>

        <button class="btn btn-secondary mt-3  " type="submit"> me connecter</button>
    </form>
    </br>
    <a href="{{ path('app_register') }}"> s'inscrire</a>
</div>
{% endblock %}
