{% extends 'base.html.twig' %}


{% block body %}
<div class="container my-5">
    <h1> Mon Panier </h1>
    {% if cart is empty %}
    <div class="alert alert-info mt-1">
        Vous n'avez ajouté aucun article au panier.
    </div>
    {% else %}
    <div class="row">
        <div class="col-md-8">

           {% for product in cart %}
                <div class="row mt-2">
                    <div class="col-md-2">
                        <img src="/uploads/{{ product.object.illustration }}" class="img-fluid" alt="image">
                    </div>
                    <div class="col-md-5">
                       <strong>{{ product.object.name }}</strong>
                        <span class="d-block"> prix unitaire : {{ product.object.priceWt|price }}</span>
                    </div>
                    <div class="col-md-2 text-right" >

                        <a href="{{ path('app_cart_edit' , {id : product.object.id} ) }}"  class= " text-decoration-none ">-</a>
                       <div  class="badge text-bg-secondary"> x{{ product.qty }}</div>
                        <a class= " text-decoration-none " href="{{ path('app_cart_add' , {id : product.object.id} ) }}">+</a>
                    </div>
                    <div class="col-md-2 " >
                        <strong>{{ (product.qty * product.object.priceWt)|price }}</strong>

                    </div>
                    <div class="col-md-1">
                        <a href="{{ path('app_cart_remove', {id: product.object.id}) }}"
                           class="text-danger fs-5 text-decoration-none ">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </div>
           {% endfor %}

        </div>



        <div class="col-md-4">

            <div class="bg-light p-2">
                <div class=" d-flex justify-content-between">
                    <span class="fw-bold">Total produits :</span>
                    <span> {{ fullcartqte }}</span>
                </div>
                <div class=" d-flex justify-content-between mt-3">
                    <span class="fw-bold">Prix total T.T.C:</span>
                    <span> {{ total }}</span>
                </div>
                <div>
                    <a href="{{ path('app_order') }}" class="btn btn-success w-100 mt-3">Commander</a>
                </div>
            </div>
        </div>

    {% endif %}
    </div>
</div>

{% endblock %}
