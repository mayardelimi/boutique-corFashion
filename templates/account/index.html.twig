{% extends 'base.html.twig' %}
{% block body %}
<div class="container my-5">
    <h1>Espace membre</h1>
    <div class=" row ">
        <div class=" col-md-3 ">
            {% include 'account/_menu.html.twig' %}
        </div>
        <div class="col-md-9">
            mes commandes
            {% if orders is empty %}
                <div class="alert alert-info">
                    Vous n'avez aucune commande
                </div>
            {% else %}
                <table class="table">
                    <thead>
                    <tr>
                        <th>N</th>
                        <th>Date</th>
                        <th>Total T.T.C</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for order in orders %}
                        <tr>
                            <td>{{ order.id }}</td>
                            <td>{{ order.createdAt|date('d/m/Y') }}</td>
                            <td>{{ order.totalWt|price }}</td>
                            <td>{{ include('admin/state.html.twig', { field: { value: order.state } }) }}</td>
                            <td>
                                <a href="{{ path('app_account_order', {'id_order': order.id }) }}">Voir</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}


        </div>
    </div>


</div>
{% endblock %}
