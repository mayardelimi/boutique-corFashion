{% extends 'base.html.twig' %}

{% block body %}
    <div class="container my-5">
        <h1 class="mb-4">Mon Wishlist</h1>

        {% if saved is empty %}
            <div class="alert alert-info shadow-sm">
                Vous n'avez ajouté aucun article au wishlist.
            </div>
        {% else %}
            <div class="row">
                <div class="col-md-9 col-lg-8">

                    {% for product in saved %}
                        <div class="row g-0 mb-3 bg-light rounded p-3 align-items-center border shadow-sm">

                            <div class="col-3 col-sm-2">
                                <img src="/uploads/{{ product.images.first.imagePath }}" class="img-fluid rounded border" alt="{{ product.name }}">
                            </div>

                            <div class="col-6 col-sm-7 ps-3">
                                <h5 class="mb-1 fw-bold text-dark">{{ product.name }}</h5>
                                <span class="text-muted small d-block">Prix unitaire : {{ product.priceWt|price }}</span>
                            </div>

                            <div class="col-3 col-sm-3 text-end d-flex flex-column align-items-end justify-content-center">
                                <a href="{{ path('app_cart_add', { 'id': product.id }) }}" class="btn btn-success btn-sm d-inline-flex align-items-center gap-2 mb-2 text-white">
                                    <i data-feather="shopping-cart" style="width: 16px; height: 16px;"></i>
                                    <span class="d-none d-sm-inline">Ajouter</span>
                                </a>
                            </div>
                        </div>
                    {% endfor %}

                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
